# 이 파일을 복사해 .env 로 만든 뒤 값을 채우세요. (.env는 git에 올라가지 않습니다)

# Turso 데이터베이스 (https://turso.tech 대시보드에서 확인)
TURSO_URL=libsql://your-db.turso.io
TURSO_TOKEN=your-turso-auth-token

# 네이버 로그인 (https://developers.naver.com → 애플리케이션 등록)
#  - 사용 API: 네이버 로그인 / 회원이름·이메일 권한
#  - Callback URL 에 아래 두 개를 모두 등록하세요:
#      http://localhost:3000/auth/naver/callback   (로컬 개발)
#      https://<your-app>.onrender.com/auth/naver/callback  (배포)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 세션 쿠키 서명 키 (아무 긴 랜덤 문자열. 미설정 시 NAVER_CLIENT_SECRET 사용)
SESSION_SECRET=please-set-a-long-random-string

# 선택: 콜백 URL 강제 지정 (미설정 시 요청 호스트에서 자동 추론)
# NAVER_REDIRECT_URI=https://your-app.onrender.com/auth/naver/callback

# 선택: 접근 허용할 네이버 이메일 화이트리스트 (쉼표 구분).
#       비워두면 네이버 로그인에 성공한 모든 계정이 각자 플래너를 갖습니다.
# ALLOWED_NAVER_EMAILS=me@naver.com,family@naver.com

# 선택: 기존 단일 플래너 데이터(id=1)를 넘겨받을 소유자 네이버 이메일.
#       이 계정이 처음 로그인할 때 기존 데이터가 이 계정으로 1회 이관됩니다.
#       (멀티 사용자 전환 시 본인 데이터 보존용. 비우면 모두 빈 플래너로 시작)
# OWNER_NAVER_EMAIL=me@naver.com

# 로컬 포트 (선택, 기본 3000)
# PORT=3000
